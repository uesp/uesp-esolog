esoCollectibleData.php:										'desc' => 'Bronze bust commemorating an Undaunted victory in Veteran Naj-Caldeesh.',
esoCollectibleData.php:										'desc' => 'Trophy taken from Molag Kena in honor of an Undaunted victory in White-Gold Tower.',
